{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "aussie-mate.vercel.app"
        }
      ],
      "destination": "https://youraussieguides.com/:path*",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.youraussieguides.com"
        }
      ],
      "destination": "https://youraussieguides.com/:path*",
      "statusCode": 301
    },
    {
      "source": "/destinations/beaches",
      "destination": "/experiences/beaches",
      "statusCode": 301
    },
    {
      "source": "/destinations/wildlife",
      "destination": "/experiences/wildlife",
      "statusCode": 301
    },
    {
      "source": "/destinations/food",
      "destination": "/experiences/food",
      "statusCode": 301
    },
    {
      "source": "/destinations/culture",
      "destination": "/experiences/culture",
      "statusCode": 301
    },
    {
      "source": "/destinations/road-trips",
      "destination": "/experiences/road-trips",
      "statusCode": 301
    }
  ]
}
